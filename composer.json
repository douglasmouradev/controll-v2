{
	"name": "controll/help-desk-crm",
	"description": "CRM Help Desk Controll - PHP MVC (no framework)",
	"type": "project",
	"require": {
		"ext-pdo": "*",
		"setasign/fpdf": "^1.8",
		"chillerlan/php-qrcode": "^5.0"
	},
	"require-dev": {
		"phpunit/phpunit": "^10.5"
	},
	"autoload": {
		"psr-4": {
			"App\\": "app/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Tests\\": "tests/"
		}
	},
	"scripts": {
		"test": "phpunit",
		"migrate": "php bin/migrate.php"
	}
}
